{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "rewrites": [
    {
      "source": "/dogs/:dogId",
      "destination": "/api/dog_meta?dogId=:dogId"
    }
  ],
  "functions": {
    "api/*.py": {
      "includeFiles": "api/index.html",
      "maxDuration": 300
    }
  },
  "crons": [
    {
      "path": "/api/pacc_inventory",
      "schedule": "0 8 * * *"
    },
    {
      "path": "/api/generate_prompts",
      "schedule": "*/30 * * * *"
    },
    {
      "path": "/api/pacc_profiles",
      "schedule": "5 * * * *"
    },
    {
      "path": "/api/mp_all",
      "schedule": "0 */6 * * *"
    },
    {
      "path": "/api/hssa_inventory",
      "schedule": "0 9 * * *"
    },
    {
      "path": "/api/hssa_profiles",
      "schedule": "10 * * * *"
    },
    {
      "path": "/api/nycacc_inventory",
      "schedule": "0 10 * * *"
    },
    {
      "path": "/api/nycacc_profiles",
      "schedule": "15 * * * *"
    }
  ]
}
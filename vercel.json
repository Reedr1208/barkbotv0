{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "functions": {
    "api/*.py": {
      "maxDuration": 300
    }
  },
  "crons": [
    {
      "path": "/api/scrape_all",
      "schedule": "0 8 * * *"
    },
    {
      "path": "/api/generate_prompts",
      "schedule": "10 * * * *"
    },
    {
      "path": "/api/scrape",
      "schedule": "5 * * * *"
    }
  ]
}
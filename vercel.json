{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "rewrites": [
    {
      "source": "/dogs/:dogId",
      "destination": "/api/dog_meta?dogId=:dogId"
    }
  ],
  "functions": {
    "api/*.py": {
      "includeFiles": "api/index.html",
      "maxDuration": 300
    }
  },
  "crons": [
    {
      "path": "/api/scrape_all",
      "schedule": "0 8 * * *"
    },
    {
      "path": "/api/generate_prompts",
      "schedule": "10 * * * *"
    },
    {
      "path": "/api/scrape",
      "schedule": "5 * * * *"
    }
  ]
}
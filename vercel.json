{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "trailingSlash": false,
  "rewrites": [
    {
      "source": "/dogs/:path1/:path2",
      "destination": "/api/dog_meta?path1=:path1&path2=:path2"
    },
    {
      "source": "/dogs/:path1",
      "destination": "/api/dog_meta?path1=:path1"
    },
    {
      "source": "/((?!api/|dogs/|_expo/|assets/|favicon|privacy\\.html|.*\\.(?:png|jpg|jpeg|gif|ico|js|json|css|svg|woff2?|ttf|otf)).*)",
      "destination": "/index.html"
    }
  ],
  "functions": {
    "api/*.py": {
      "includeFiles": "api/index.html",
      "maxDuration": 300
    }
  },
  "crons": [
    {
      "path": "/api/pacc_inventory",
      "schedule": "0 8 * * *"
    },
    {
      "path": "/api/generate_prompts",
      "schedule": "*/30 * * * *"
    },
    {
      "path": "/api/pacc_profiles",
      "schedule": "5 * * * *"
    },
    {
      "path": "/api/mp_all",
      "schedule": "0 */6 * * *"
    },
    {
      "path": "/api/wwla_all",
      "schedule": "0 */4 * * *"
    },
    {
      "path": "/api/pawsch_inventory",
      "schedule": "0 */4 * * *"
    },
    {
      "path": "/api/pawsch_profiles",
      "schedule": "20 * * * *"
    },

    {
      "path": "/api/php_profiles",
      "schedule": "35 * * * *"
    },

    {
      "path": "/api/mcacc_inventory",
      "schedule": "15 */4 * * *"
    },
    {
      "path": "/api/mcacc_profiles",
      "schedule": "50 * * * *"
    },
    {
      "path": "/api/rchs_inventory",
      "schedule": "30 */4 * * *"
    },
    {
      "path": "/api/rchs_profiles",
      "schedule": "10 * * * *"
    },
    {
      "path": "/api/dpa_inventory",
      "schedule": "40 */4 * * *"
    },
    {
      "path": "/api/dpa_profiles",
      "schedule": "25 * * * *"
    },
    {
      "path": "/api/nhs_inventory",
      "schedule": "45 */4 * * *"
    },
    {
      "path": "/api/nhs_profiles",
      "schedule": "55 * * * *"
    },
    {
      "path": "/api/ehr_inventory",
      "schedule": "50 */4 * * *"
    },
    {
      "path": "/api/ehr_profiles",
      "schedule": "35 * * * *"
    },
    {
      "path": "/api/mv_inventory",
      "schedule": "0 */4 * * *"
    },
    {
      "path": "/api/mv_profiles",
      "schedule": "45 * * * *"
    },
    {
      "path": "/api/rdr_inventory",
      "schedule": "5 */4 * * *"
    },
    {
      "path": "/api/rdr_profiles",
      "schedule": "15 * * * *"
    }
  ]
}
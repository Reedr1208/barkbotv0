{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "rewrites": [
    {
      "source": "/dogs/:dogId",
      "has": [
        {
          "type": "header",
          "key": "user-agent",
          "value": ".*(facebookexternalhit|Facebot|Twitterbot|LinkedInBot|Slackbot|WhatsApp|TelegramBot|Discordbot|Pinterestbot|Googlebot|bingbot|Applebot).*"
        }
      ],
      "destination": "/api/dog_meta?dogId=:dogId"
    },
    {
      "source": "/dogs/:dogId",
      "destination": "/index.html"
    }
  ],
  "functions": {
    "api/dog_meta.py": {
      "includeFiles": "public/index.html",
      "maxDuration": 300
    },
    "api/*.py": {
      "maxDuration": 300
    }
  },
  "crons": [
    {
      "path": "/api/scrape_all",
      "schedule": "0 8 * * *"
    },
    {
      "path": "/api/generate_prompts",
      "schedule": "10 * * * *"
    },
    {
      "path": "/api/scrape",
      "schedule": "5 * * * *"
    }
  ]
}